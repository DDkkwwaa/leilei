<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shanzhu.purchase.dao.JxPurchaseExitDao">
    <select id="selectNumber" resultType="com.shanzhu.purchase.model.JxmdPurchaseExit">
        select * from jxmd_purchase_exit where number = #{sourceNumber}
    </select>

    <select id="getByField" resultType="com.shanzhu.purchase.model.JxmdPurchaseExit">
        select * from jxmd_purchase_exit where number = #{checkNumber}
    </select>
</mapper>
